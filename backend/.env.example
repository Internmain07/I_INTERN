# ===========================================
# I-INTERN BACKEND - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ===========================================
# CORE APPLICATION SETTINGS
# ===========================================

# Secret key for JWT token generation (use a strong random string)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-this-to-random-string

# Database connection URL
# Development (SQLite): sqlite:///./test.db
# Production (PostgreSQL): postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///./test.db

# Environment mode: development, staging, or production
ENVIRONMENT=development

# ===========================================
# URL CONFIGURATION
# ===========================================

# Frontend URL (for password reset links, welcome emails, etc.)
# Development: http://localhost:8081
# Production: https://i-intern.com
FRONTEND_URL=http://localhost:8081

# Backend URL (for OAuth callbacks, API documentation, etc.)
# Development: http://localhost:8000
# Production: https://your-backend-url.onrender.com
BACKEND_URL=http://localhost:8000

# Allowed CORS origins (comma-separated list)
# Development: include localhost URLs
# Production: include only your production domains
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173,http://localhost:3000

# ===========================================
# EMAIL/SMTP CONFIGURATION
# ===========================================
# Required for: Password reset, Email verification, Welcome emails
# Leave blank in development to skip sending emails (will print to console)

# SMTP Server (Gmail: smtp.gmail.com)
SMTP_SERVER=smtp.gmail.com

# SMTP Port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP Username (your email address)
SMTP_USERNAME=your-email@gmail.com

# SMTP Password (use Gmail App Password, not regular password)
# How to get Gmail App Password:
# 1. Enable 2-factor authentication on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create a new app password for "Mail"
# 4. Use that 16-character password here
SMTP_PASSWORD=your-app-password-here

# From Email (sender email address shown in emails)
FROM_EMAIL=noreply@i-intern.com

# ===========================================
# GOOGLE OAUTH (OPTIONAL)
# ===========================================
# Currently disabled in code. Uncomment endpoints in auth.py to enable
# Get credentials from: https://console.cloud.google.com/apis/credentials

# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# ADDITIONAL SETTINGS (Advanced)
# ===========================================

# Build settings for Render.com (only needed on Render)
# CARGO_HOME=/opt/render/project/.cargo
# CARGO_TARGET_DIR=/opt/render/project/.cargo-target
